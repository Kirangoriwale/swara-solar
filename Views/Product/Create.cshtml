@model SolarBilling.Models.Product

@{
    ViewData["Title"] = "Create Product";
}

<div class="page-header d-flex justify-content-between align-items-center mb-2">
    <h2 class="text-primary mb-0"><i class="bi bi-box-seam me-2"></i>Create Product</h2>
</div>

<div class="card shadow-sm rounded-lg">
    <div class="card-body p-3">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-2" role="alert"></div>
            
            <!-- Product Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-info-circle me-1"></i>Product Information</h6>
                <div class="row g-2">
                    <div class="col-md-12">
                        <label asp-for="Name" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Name" class="form-control form-control-sm" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label small fw-semibold mb-1"></label>
                        <textarea asp-for="Description" class="form-control form-control-sm" rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="HSNCode" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="HSNCode" class="form-control form-control-sm" />
                        <span asp-validation-for="HSNCode" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Unit" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Unit" class="form-control form-control-sm" value="Nos" />
                        <span asp-validation-for="Unit" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Pricing Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-currency-rupee me-1"></i>Pricing Information</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="MRP" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="MRP" class="form-control form-control-sm" type="number" step="0.01" />
                        <span asp-validation-for="MRP" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="UnitPrice" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="UnitPrice" class="form-control form-control-sm" type="number" step="0.01" />
                        <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="TaxRate" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="TaxRate" class="form-control form-control-sm" type="number" step="0.01" value="18.00" />
                        <span asp-validation-for="TaxRate" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Status Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-toggle-on me-1"></i>Status</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label small fw-semibold"></label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-end gap-2 mt-2 pt-2 border-top">
                <a asp-action="Index" class="btn btn-secondary btn-sm">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </a>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-check-circle me-1"></i>Create Product
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
