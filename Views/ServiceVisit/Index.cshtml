@model IEnumerable<SolarBilling.Models.ServiceVisit>

@{
    ViewData["Title"] = "Service Visits";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">
        <i class="bi bi-tools text-primary me-2"></i>Service Visits
    </h2>
    <div>
        <a asp-action="Upcoming" class="btn btn-warning btn-sm me-2">
            <i class="bi bi-calendar-check me-1"></i>Upcoming Visits
        </a>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Create New Service Visit
        </a>
    </div>
</div>

<!-- Results Table -->
<div class="card shadow-sm rounded-lg">
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th class="text-white fw-bold">Visit Date</th>
                            <th class="text-white fw-bold">AMC Number</th>
                            <th class="text-white fw-bold">Customer</th>
                            <th class="text-white fw-bold">Service Engineer</th>
                            <th class="text-end text-white fw-bold">Total Amount</th>
                            <th class="text-white fw-bold">Status</th>
                            <th class="text-center text-white fw-bold">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.VisitDate.ToString("dd MMM yyyy")</td>
                                <td><strong>@Html.DisplayFor(modelItem => item.AMC.AMCNumber)</strong></td>
                                <td>@Html.DisplayFor(modelItem => item.AMC.Customer.Name)</td>
                                <td>@Html.DisplayFor(modelItem => item.ServiceEngineer)</td>
                                <td class="text-end">
                                    @if (item.TotalAmount.HasValue)
                                    {
                                        <text>₹ @Html.DisplayFor(modelItem => item.TotalAmount)</text>
                                    }
                                    else
                                    {
                                        <text>-</text>
                                    }
                                </td>
                                <td>
                                    @if (item.Status == "Completed")
                                    {
                                        <span class="badge bg-success">@item.Status</span>
                                    }
                                    else if (item.Status == "In Progress")
                                    {
                                        <span class="badge bg-info">@item.Status</span>
                                    }
                                    else if (item.Status == "Cancelled")
                                    {
                                        <span class="badge bg-danger">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">@item.Status</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox display-4 text-muted"></i>
                <p class="text-muted mt-3">
                    No service visits found. <a asp-action="Create">Create a new service visit</a> to get started.
                </p>
            </div>
        }
    </div>
</div>

