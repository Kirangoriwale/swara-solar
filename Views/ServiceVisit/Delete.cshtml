@model SolarBilling.Models.ServiceVisit

@{
    ViewData["Title"] = "Delete Service Visit";
}

<div class="page-header d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-danger mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Delete Service Visit</h2>
</div>

<div class="alert alert-warning d-flex align-items-center mb-3" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem;"></i>
    <div>
        <strong>Warning!</strong> Are you sure you want to delete this service visit? This action cannot be undone.
    </div>
</div>

<div class="card shadow-sm rounded-lg mb-3">
    <div class="card-body">
        <h6 class="text-primary border-bottom pb-1 mb-3 small fw-semibold"><i class="bi bi-info-circle me-1"></i>Service Visit Information</h6>
        <dl class="row mb-0">
            <dt class="col-sm-3"><i class="bi bi-shield-check me-1"></i>AMC Number</dt>
            <dd class="col-sm-9"><strong>@Html.DisplayFor(model => model.AMC.AMCNumber)</strong></dd>

            <dt class="col-sm-3"><i class="bi bi-person me-1"></i>Customer</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.AMC.Customer.Name)</dd>

            <dt class="col-sm-3"><i class="bi bi-calendar-check me-1"></i>@Html.DisplayNameFor(model => model.VisitDate)</dt>
            <dd class="col-sm-9">@Model.VisitDate.ToString("dd MMM yyyy")</dd>

            @if (Model.VisitTime.HasValue)
            {
                <dt class="col-sm-3"><i class="bi bi-clock me-1"></i>@Html.DisplayNameFor(model => model.VisitTime)</dt>
                <dd class="col-sm-9">@Model.VisitTime.Value.ToString(@"hh\:mm")</dd>
            }

            <dt class="col-sm-3"><i class="bi bi-person-badge me-1"></i>@Html.DisplayNameFor(model => model.ServiceEngineer)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ServiceEngineer)</dd>

            @if (!string.IsNullOrEmpty(Model.EngineerContact))
            {
                <dt class="col-sm-3"><i class="bi bi-telephone me-1"></i>@Html.DisplayNameFor(model => model.EngineerContact)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.EngineerContact)</dd>
            }

            <dt class="col-sm-3"><i class="bi bi-flag me-1"></i>@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class="col-sm-9">
                @if (Model.Status == "Completed")
                {
                    <span class="badge bg-success">@Model.Status</span>
                }
                else if (Model.Status == "In Progress")
                {
                    <span class="badge bg-info">@Model.Status</span>
                }
                else if (Model.Status == "Cancelled")
                {
                    <span class="badge bg-danger">@Model.Status</span>
                }
                else
                {
                    <span class="badge bg-warning">@Model.Status</span>
                }
            </dd>
        </dl>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.WorkDescription))
{
    <div class="card shadow-sm rounded-lg mb-3">
        <div class="card-body">
            <h6 class="text-primary border-bottom pb-1 mb-3 small fw-semibold"><i class="bi bi-clipboard-check me-1"></i>Work Description</h6>
            <p class="mb-0">@Html.DisplayFor(model => model.WorkDescription)</p>
        </div>
    </div>
}

@if (Model.PartsCost.HasValue || Model.ServiceCharge.HasValue || Model.TotalAmount.HasValue)
{
    <div class="card shadow-sm rounded-lg mb-3">
        <div class="card-body">
            <h6 class="text-primary border-bottom pb-1 mb-3 small fw-semibold"><i class="bi bi-currency-dollar me-1"></i>Financial Information</h6>
            <dl class="row mb-0">
                @if (Model.PartsCost.HasValue)
                {
                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PartsCost)</dt>
                    <dd class="col-sm-9">₹ @Html.DisplayFor(model => model.PartsCost)</dd>
                }
                @if (Model.ServiceCharge.HasValue)
                {
                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ServiceCharge)</dt>
                    <dd class="col-sm-9">₹ @Html.DisplayFor(model => model.ServiceCharge)</dd>
                }
                @if (Model.TotalAmount.HasValue)
                {
                    <dt class="col-sm-3"><strong>@Html.DisplayNameFor(model => model.TotalAmount)</strong></dt>
                    <dd class="col-sm-9"><strong>₹ @Html.DisplayFor(model => model.TotalAmount)</strong></dd>
                }
            </dl>
        </div>
    </div>
}

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-secondary btn-sm">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </a>
        <button type="submit" class="btn btn-danger btn-sm">
            <i class="bi bi-trash me-1"></i>Delete Service Visit
        </button>
    </div>
</form>

