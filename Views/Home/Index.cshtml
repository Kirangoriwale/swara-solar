@{
    ViewData["Title"] = "Home";
}

<div class="text-center mb-4">
    <h1 class="display-5 mb-2">Solar Panel Billing System</h1>
    <p class="lead mb-0" style="font-size: 1rem;">Manage your solar panel business with ease and efficiency</p>
</div>

<div class="row g-3">
    <div class="col-6 col-md-4 col-lg mb-3">
        <div class="card text-center h-100" style="border-left: 4px solid #667eea;">
            <div class="card-body p-3">
                <div class="mb-2">
                    <i class="bi bi-building" style="font-size: 2rem; color: #667eea;"></i>
                </div>
                <h6 class="card-title mb-2">Company</h6>
                <p class="card-text small mb-2">Manage company information</p>
                <div class="d-grid gap-1">
                    <a asp-controller="Company" asp-action="Index" class="btn btn-sm btn-primary">
                        <i class="bi bi-list-ul me-1"></i>View
                    </a>
                    <a asp-controller="Company" asp-action="Create" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-plus-circle me-1"></i>Add New
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg mb-3">
        <div class="card text-center h-100" style="border-left: 4px solid #10b981;">
            <div class="card-body p-3">
                <div class="mb-2">
                    <i class="bi bi-people" style="font-size: 2rem; color: #10b981;"></i>
                </div>
                <h6 class="card-title mb-2">Customers</h6>
                <p class="card-text small mb-2">Manage customer information</p>
                <div class="d-grid gap-1">
                    <a asp-controller="Customer" asp-action="Index" class="btn btn-sm btn-success">
                        <i class="bi bi-list-ul me-1"></i>View
                    </a>
                    <a asp-controller="Customer" asp-action="Create" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-plus-circle me-1"></i>Add New
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg mb-3">
        <div class="card text-center h-100" style="border-left: 4px solid #f59e0b;">
            <div class="card-body p-3">
                <div class="mb-2">
                    <i class="bi bi-box-seam" style="font-size: 2rem; color: #f59e0b;"></i>
                </div>
                <h6 class="card-title mb-2">Products</h6>
                <p class="card-text small mb-2">Create and Manage product catalog</p>
                <div class="d-grid gap-1">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-warning text-white">
                        <i class="bi bi-list-ul me-1"></i>View
                    </a>
                    <a asp-controller="Product" asp-action="Create" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-plus-circle me-1"></i>Add New
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg mb-3">
        <div class="card text-center h-100" style="border-left: 4px solid #06b6d4;">
            <div class="card-body p-3">
                <div class="mb-2">
                    <i class="bi bi-file-earmark-text" style="font-size: 2rem; color: #06b6d4;"></i>
                </div>
                <h6 class="card-title mb-2">Quotations</h6>
                <p class="card-text small mb-2">Create and manage quotations</p>
                <div class="d-grid gap-1">
                    <a asp-controller="Quotation" asp-action="Index" class="btn btn-sm btn-info text-white">
                        <i class="bi bi-list-ul me-1"></i>View
                    </a>
                    <a asp-controller="Quotation" asp-action="Create" class="btn btn-sm btn-outline-info">
                        <i class="bi bi-plus-circle me-1"></i>Create New
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg mb-3">
        <div class="card text-center h-100" style="border-left: 4px solid #8b5cf6;">
            <div class="card-body p-3">
                <div class="mb-2">
                    <i class="bi bi-receipt" style="font-size: 2rem; color: #8b5cf6;"></i>
                </div>
                <h6 class="card-title mb-2">Invoices</h6>
                <p class="card-text small mb-2">Create and manage invoices</p>
                <div class="d-grid gap-1">
                    <a asp-controller="Invoice" asp-action="Index" class="btn btn-sm" style="background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%); color: white; border: none;">
                        <i class="bi bi-list-ul me-1"></i>View
                    </a>
                    <a asp-controller="Invoice" asp-action="Create" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-plus-circle me-1"></i>Create New
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg mb-3">
        <div class="card text-center h-100" style="border-left: 4px solid #ec4899;">
            <div class="card-body p-3">
                <div class="mb-2">
                    <i class="bi bi-shield-check" style="font-size: 2rem; color: #ec4899;"></i>
                </div>
                <h6 class="card-title mb-2">AMC Management</h6>
                <p class="card-text small mb-2">Manage Annual Maintenance Contracts</p>
                <div class="d-grid gap-1">
                    <a asp-controller="AMC" asp-action="Index" class="btn btn-sm" style="background: linear-gradient(135deg, #ec4899 0%, #db2777 100%); color: white; border: none;">
                        <i class="bi bi-list-ul me-1"></i>View
                    </a>
                    <a asp-controller="AMC" asp-action="Create" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-plus-circle me-1"></i>Create New
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg mb-3">
        <div class="card text-center h-100" style="border-left: 4px solid #14b8a6;">
            <div class="card-body p-3">
                <div class="mb-2">
                    <i class="bi bi-tools" style="font-size: 2rem; color: #14b8a6;"></i>
                </div>
                <h6 class="card-title mb-2">Service Visits</h6>
                <p class="card-text small mb-2">Track and manage service visits</p>
                <div class="d-grid gap-1">
                    <a asp-controller="ServiceVisit" asp-action="Index" class="btn btn-sm" style="background: linear-gradient(135deg, #14b8a6 0%, #0d9488 100%); color: white; border: none;">
                        <i class="bi bi-list-ul me-1"></i>View
                    </a>
                    <a asp-controller="ServiceVisit" asp-action="Create" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-plus-circle me-1"></i>Create New
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg mb-3">
        <div class="card text-center h-100" style="border-left: 4px solid #f59e0b;">
            <div class="card-body p-3">
                <div class="mb-2">
                    <i class="bi bi-calendar-check" style="font-size: 2rem; color: #f59e0b;"></i>
                </div>
                <h6 class="card-title mb-2">Upcoming Visits</h6>
                <p class="card-text small mb-2">View scheduled service visits</p>
                <div class="d-grid gap-1">
                    <a asp-controller="ServiceVisit" asp-action="Upcoming" class="btn btn-sm" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; border: none;">
                        <i class="bi bi-calendar-check me-1"></i>View Upcoming
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
