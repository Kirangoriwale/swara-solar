@model IEnumerable<SolarBilling.Models.Invoice>

@{
    ViewData["Title"] = "Invoices";
    var searchString = ViewBag.SearchString as string ?? "";
    var pageNumber = ViewBag.PageNumber ?? 1;
    var pageSize = ViewBag.PageSize ?? 10;
    var totalRecords = ViewBag.TotalRecords ?? 0;
    var totalPages = ViewBag.TotalPages ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">
        <i class="bi bi-receipt text-purple me-2"></i>Invoices
    </h2>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Create New Invoice
    </a>
</div>

<!-- Search Section -->
<div class="card shadow-sm rounded-lg mb-3">
    <div class="card-body p-3">
        <form asp-action="Index" method="get" class="row g-2 align-items-end">
            <div class="col-md-8">
                <label for="searchString" class="form-label small fw-semibold mb-1">Search</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchString" id="searchString" class="form-control" value="@searchString" placeholder="Search by Invoice Number, Customer Name, or PO Number..." />
                </div>
            </div>
            <div class="col-md-2">
                <label for="pageSize" class="form-label small fw-semibold mb-1">Items per Page</label>
                <select name="pageSize" id="pageSize" class="form-select form-select-sm">
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="25" selected="@(pageSize == 25)">25</option>
                    <option value="50" selected="@(pageSize == 50)">50</option>
                    <option value="100" selected="@(pageSize == 100)">100</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i>Search
                </button>
            </div>
        </form>
        @if (!string.IsNullOrWhiteSpace(searchString))
        {
            <div class="mt-2">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-x-circle me-1"></i>Clear Search
                </a>
                <span class="small text-muted ms-2">Found @totalRecords record(s)</span>
            </div>
        }
    </div>
</div>

<!-- Results Table -->
<div class="card shadow-sm rounded-lg">
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th class="text-white fw-bold">Invoice Number</th>
                            <th class="text-white fw-bold">Date</th>
                            <th class="text-white fw-bold">Customer</th>
                            <th class="text-end text-white fw-bold">Subtotal</th>
                            <th class="text-end text-white fw-bold">Tax</th>
                            <th class="text-end text-white fw-bold">Total</th>
                            <th class="text-center text-white fw-bold">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@Html.DisplayFor(modelItem => item.InvoiceNumber)</strong></td>
                                <td>@item.InvoiceDate.ToString("dd MMM yyyy")</td>
                                <td>@Html.DisplayFor(modelItem => item.Customer.Name)</td>
                                <td class="text-end">₹ @Html.DisplayFor(modelItem => item.Subtotal)</td>
                                <td class="text-end">₹ @Html.DisplayFor(modelItem => item.TaxAmount)</td>
                                <td class="text-end"><strong>₹ @Html.DisplayFor(modelItem => item.TotalAmount)</strong></td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="DownloadPdf" asp-route-id="@item.Id" class="btn btn-sm btn-success" title="Download PDF">
                                            <i class="bi bi-file-pdf"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="card-footer bg-white border-top p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="small text-muted">
                            Showing @((pageNumber - 1) * pageSize + 1) to @(Math.Min(pageNumber * pageSize, totalRecords)) of @totalRecords entries
                        </div>
                        <nav aria-label="Page navigation">
                            <ul class="pagination pagination-sm mb-0">
                                @if (pageNumber > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Index" asp-route-searchString="@searchString" asp-route-pageNumber="1" asp-route-pageSize="@pageSize">
                                            <i class="bi bi-chevron-double-left"></i>
                                        </a>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Index" asp-route-searchString="@searchString" asp-route-pageNumber="@(pageNumber - 1)" asp-route-pageSize="@pageSize">
                                            <i class="bi bi-chevron-left"></i>
                                        </a>
                                    </li>
                                }
                                else
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link"><i class="bi bi-chevron-double-left"></i></span>
                                    </li>
                                    <li class="page-item disabled">
                                        <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                                    </li>
                                }

                                @{
                                    int startPage = Math.Max(1, pageNumber - 2);
                                    int endPage = Math.Min(totalPages, pageNumber + 2);
                                }

                                @if (startPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Index" asp-route-searchString="@searchString" asp-route-pageNumber="1" asp-route-pageSize="@pageSize">1</a>
                                    </li>
                                    @if (startPage > 2)
                                    {
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    }
                                }

                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == pageNumber ? "active" : "")">
                                        <a class="page-link" asp-action="Index" asp-route-searchString="@searchString" asp-route-pageNumber="@i" asp-route-pageSize="@pageSize">@i</a>
                                    </li>
                                }

                                @if (endPage < totalPages)
                                {
                                    @if (endPage < totalPages - 1)
                                    {
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    }
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Index" asp-route-searchString="@searchString" asp-route-pageNumber="@totalPages" asp-route-pageSize="@pageSize">@totalPages</a>
                                    </li>
                                }

                                @if (pageNumber < totalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Index" asp-route-searchString="@searchString" asp-route-pageNumber="@(pageNumber + 1)" asp-route-pageSize="@pageSize">
                                            <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Index" asp-route-searchString="@searchString" asp-route-pageNumber="@totalPages" asp-route-pageSize="@pageSize">
                                            <i class="bi bi-chevron-double-right"></i>
                                        </a>
                                    </li>
                                }
                                else
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                                    </li>
                                    <li class="page-item disabled">
                                        <span class="page-link"><i class="bi bi-chevron-double-right"></i></span>
                                    </li>
                                }
                            </ul>
                        </nav>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox display-4 text-muted"></i>
                <p class="text-muted mt-3">
                    @if (!string.IsNullOrWhiteSpace(searchString))
                    {
                        <text>No invoices found matching your search criteria.</text>
                    }
                    else
                    {
                        <text>No invoices found. <a asp-action="Create">Create a new invoice</a> to get started.</text>
                    }
                </p>
            </div>
        }
    </div>
</div>
