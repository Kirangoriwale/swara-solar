@model SolarBilling.Models.AMC

@{
    ViewData["Title"] = "AMC Details";
}

<div class="page-header d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-primary mb-0"><i class="bi bi-shield-check me-2"></i>AMC Details</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>
</div>

<div class="card shadow-sm rounded-lg mb-3">
    <div class="card-body">
        <h6 class="text-primary border-bottom pb-1 mb-3 small fw-semibold"><i class="bi bi-info-circle me-1"></i>AMC Information</h6>
        <dl class="row mb-0">
            <dt class="col-sm-3"><i class="bi bi-hash me-1"></i>@Html.DisplayNameFor(model => model.AMCNumber)</dt>
            <dd class="col-sm-9"><strong>@Html.DisplayFor(model => model.AMCNumber)</strong></dd>

            <dt class="col-sm-3"><i class="bi bi-person me-1"></i>@Html.DisplayNameFor(model => model.Customer)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Customer.Name)</dd>

            <dt class="col-sm-3"><i class="bi bi-calendar-check me-1"></i>@Html.DisplayNameFor(model => model.StartDate)</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3"><i class="bi bi-calendar-x me-1"></i>@Html.DisplayNameFor(model => model.EndDate)</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3"><i class="bi bi-currency-dollar me-1"></i>@Html.DisplayNameFor(model => model.AMCAmount)</dt>
            <dd class="col-sm-9">₹ @Html.DisplayFor(model => model.AMCAmount)</dd>

            <dt class="col-sm-3"><i class="bi bi-arrow-repeat me-1"></i>@Html.DisplayNameFor(model => model.Frequency)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Frequency)</dd>

            <dt class="col-sm-3"><i class="bi bi-list-ol me-1"></i>@Html.DisplayNameFor(model => model.NumberOfVisits)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.NumberOfVisits)</dd>

            <dt class="col-sm-3"><i class="bi bi-flag me-1"></i>@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class="col-sm-9">
                @if (Model.Status == "Active")
                {
                    <span class="badge bg-success">@Model.Status</span>
                }
                else if (Model.Status == "Expired")
                {
                    <span class="badge bg-danger">@Model.Status</span>
                }
                else if (Model.Status == "Cancelled")
                {
                    <span class="badge bg-secondary">@Model.Status</span>
                }
                else
                {
                    <span class="badge bg-info">@Model.Status</span>
                }
            </dd>
        </dl>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <div class="card shadow-sm rounded-lg mb-3">
        <div class="card-body">
            <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-file-text me-1"></i>Description</h6>
            <p class="mb-0">@Html.DisplayFor(model => model.Description)</p>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.TermsConditions))
{
    <div class="card shadow-sm rounded-lg mb-3">
        <div class="card-body">
            <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-file-earmark-text me-1"></i>Terms & Conditions</h6>
            <p class="mb-0">@Html.DisplayFor(model => model.TermsConditions)</p>
        </div>
    </div>
}

<div class="card shadow-sm rounded-lg mb-3">
    <div class="card-body">
        <h6 class="text-primary border-bottom pb-1 mb-3 small fw-semibold"><i class="bi bi-telephone me-1"></i>Contact Information</h6>
        <dl class="row mb-0">
            <dt class="col-sm-3"><i class="bi bi-person-badge me-1"></i>@Html.DisplayNameFor(model => model.ContactPerson)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ContactPerson)</dd>

            <dt class="col-sm-3"><i class="bi bi-phone me-1"></i>@Html.DisplayNameFor(model => model.ContactPhone)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ContactPhone)</dd>

            <dt class="col-sm-3"><i class="bi bi-envelope me-1"></i>@Html.DisplayNameFor(model => model.ContactEmail)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ContactEmail)</dd>
        </dl>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ServiceAddress))
{
    <div class="card shadow-sm rounded-lg mb-3">
        <div class="card-body">
            <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-geo-alt me-1"></i>Service Address</h6>
            <p class="mb-0">@Html.DisplayFor(model => model.ServiceAddress)</p>
        </div>
    </div>
}

@if (Model.ServiceVisits != null && Model.ServiceVisits.Any())
{
    <div class="card shadow-sm rounded-lg mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="text-primary border-bottom pb-1 mb-0 small fw-semibold"><i class="bi bi-tools me-1"></i>Service Visits</h6>
                <a asp-controller="ServiceVisit" asp-action="Create" asp-route-amcId="@Model.Id" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-circle me-1"></i>Add Service Visit
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Visit Date</th>
                            <th>Service Engineer</th>
                            <th>Status</th>
                            <th>Total Amount</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var visit in Model.ServiceVisits.OrderByDescending(v => v.VisitDate))
                        {
                            <tr>
                                <td>@visit.VisitDate.ToString("dd MMM yyyy")</td>
                                <td>@Html.DisplayFor(modelItem => visit.ServiceEngineer)</td>
                                <td>
                                    @if (visit.Status == "Completed")
                                    {
                                        <span class="badge bg-success">@visit.Status</span>
                                    }
                                    else if (visit.Status == "In Progress")
                                    {
                                        <span class="badge bg-info">@visit.Status</span>
                                    }
                                    else if (visit.Status == "Cancelled")
                                    {
                                        <span class="badge bg-danger">@visit.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">@visit.Status</span>
                                    }
                                </td>
                                <td>
                                    @if (visit.TotalAmount.HasValue)
                                    {
                                        <text>₹ @visit.TotalAmount.Value.ToString("0.00")</text>
                                    }
                                    else
                                    {
                                        <text>-</text>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-controller="ServiceVisit" asp-action="Details" asp-route-id="@visit.Id" class="btn btn-sm btn-info" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <h6 class="text-primary border-bottom pb-1 mb-3 small fw-semibold"><i class="bi bi-clock-history me-1"></i>Audit Information</h6>
        <dl class="row mb-0">
            <dt class="col-sm-3"><i class="bi bi-calendar-plus me-1"></i>Created Date</dt>
            <dd class="col-sm-9">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</dd>

            @if (Model.ModifiedDate.HasValue)
            {
                <dt class="col-sm-3"><i class="bi bi-calendar-check me-1"></i>Modified Date</dt>
                <dd class="col-sm-9">@Model.ModifiedDate.Value.ToString("dd MMM yyyy HH:mm")</dd>
            }
        </dl>
    </div>
</div>

