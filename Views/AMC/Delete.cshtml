@model SolarBilling.Models.AMC

@{
    ViewData["Title"] = "Delete AMC";
}

<div class="page-header d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-danger mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Delete AMC</h2>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2" style="font-size: 1.5rem;"></i>
        <div>@TempData["ErrorMessage"]</div>
    </div>
}

<div class="alert alert-warning d-flex align-items-center mb-3" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem;"></i>
    <div>
        <strong>Warning!</strong> Are you sure you want to delete this AMC? This action cannot be undone.
        @if (Model.ServiceVisits != null && Model.ServiceVisits.Any())
        {
            <br />
            <small class="text-danger">This AMC has @Model.ServiceVisits.Count() associated service visit(s). Deleting this AMC will also delete all associated service visits.</small>
        }
    </div>
</div>

<div class="card shadow-sm rounded-lg mb-3">
    <div class="card-body">
        <h6 class="text-primary border-bottom pb-1 mb-3 small fw-semibold"><i class="bi bi-info-circle me-1"></i>AMC Information</h6>
        <dl class="row mb-0">
            <dt class="col-sm-3"><i class="bi bi-hash me-1"></i>@Html.DisplayNameFor(model => model.AMCNumber)</dt>
            <dd class="col-sm-9"><strong>@Html.DisplayFor(model => model.AMCNumber)</strong></dd>

            <dt class="col-sm-3"><i class="bi bi-person me-1"></i>@Html.DisplayNameFor(model => model.Customer)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Customer.Name)</dd>

            <dt class="col-sm-3"><i class="bi bi-calendar-check me-1"></i>@Html.DisplayNameFor(model => model.StartDate)</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3"><i class="bi bi-calendar-x me-1"></i>@Html.DisplayNameFor(model => model.EndDate)</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3"><i class="bi bi-currency-dollar me-1"></i>@Html.DisplayNameFor(model => model.AMCAmount)</dt>
            <dd class="col-sm-9">₹ @Html.DisplayFor(model => model.AMCAmount)</dd>

            <dt class="col-sm-3"><i class="bi bi-arrow-repeat me-1"></i>@Html.DisplayNameFor(model => model.Frequency)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Frequency)</dd>

            <dt class="col-sm-3"><i class="bi bi-list-ol me-1"></i>@Html.DisplayNameFor(model => model.NumberOfVisits)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.NumberOfVisits)</dd>

            <dt class="col-sm-3"><i class="bi bi-flag me-1"></i>@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class="col-sm-9">
                @if (Model.Status == "Active")
                {
                    <span class="badge bg-success">@Model.Status</span>
                }
                else if (Model.Status == "Expired")
                {
                    <span class="badge bg-danger">@Model.Status</span>
                }
                else if (Model.Status == "Cancelled")
                {
                    <span class="badge bg-secondary">@Model.Status</span>
                }
                else
                {
                    <span class="badge bg-info">@Model.Status</span>
                }
            </dd>
        </dl>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <div class="card shadow-sm rounded-lg mb-3">
        <div class="card-body">
            <h6 class="text-primary border-bottom pb-1 mb-3 small fw-semibold"><i class="bi bi-file-text me-1"></i>Description</h6>
            <p class="mb-0">@Html.DisplayFor(model => model.Description)</p>
        </div>
    </div>
}

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-secondary btn-sm">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </a>
        <button type="submit" class="btn btn-danger btn-sm">
            <i class="bi bi-trash me-1"></i>Delete AMC
        </button>
    </div>
</form>

