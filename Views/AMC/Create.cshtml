@model SolarBilling.Models.AMC
@using Microsoft.AspNetCore.Mvc.Rendering
@using Microsoft.EntityFrameworkCore
@inject SolarBilling.Data.ApplicationDbContext DbContext

@{
    ViewData["Title"] = "Create AMC";
    var customers = await DbContext.Customers.OrderBy(c => c.Name).ToListAsync();
}

<div class="page-header d-flex justify-content-between align-items-center mb-2">
    <h2 class="text-primary mb-0"><i class="bi bi-shield-check me-2"></i>Create AMC</h2>
</div>

<div class="card shadow-sm rounded-lg">
    <div class="card-body p-3">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-2" role="alert"></div>
            
            <!-- AMC Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-info-circle me-1"></i>AMC Information</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="AMCNumber" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="AMCNumber" class="form-control form-control-sm" />
                        <span asp-validation-for="AMCNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CustomerId" class="form-label small fw-semibold mb-1"></label>
                        <select name="CustomerId" id="CustomerId" class="form-select form-select-sm">
                            <option value="">-- Select Customer --</option>
                            @foreach (var customer in customers)
                            {
                                <option value="@customer.Id" 
                                        data-contact-person="@(customer.ContactPerson ?? "")"
                                        data-contact-phone="@(customer.Phone ?? customer.Mobile ?? "")"
                                        data-contact-email="@(customer.Email ?? "")"
                                        data-shipping-address-line1="@(customer.ShippingAddressLine1 ?? "")"
                                        data-shipping-address-line2="@(customer.ShippingAddressLine2 ?? "")"
                                        data-shipping-city="@(customer.ShippingCity ?? "")"
                                        data-shipping-state="@(customer.ShippingState ?? "")"
                                        data-shipping-pincode="@(customer.ShippingPinCode ?? "")">@customer.Name</option>
                            }
                        </select>
                        <span asp-validation-for="CustomerId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Status" class="form-label small fw-semibold mb-1"></label>
                        <select asp-for="Status" class="form-select form-select-sm">
                            <option value="Active">Active</option>
                            <option value="Expired">Expired</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Date Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-calendar me-1"></i>Date Information</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="StartDate" class="form-control form-control-sm" type="date" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="EndDate" class="form-control form-control-sm" type="date" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Financial Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-currency-dollar me-1"></i>Financial Information</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="AMCAmount" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="AMCAmount" class="form-control form-control-sm" type="number" step="0.01" />
                        <span asp-validation-for="AMCAmount" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Frequency" class="form-label small fw-semibold mb-1"></label>
                        <select asp-for="Frequency" class="form-select form-select-sm">
                            <option value="">-- Select Frequency --</option>
                            <option value="Monthly">Monthly</option>
                            <option value="Quarterly">Quarterly</option>
                            <option value="Half-Yearly">Half-Yearly</option>
                            <option value="Yearly">Yearly</option>
                        </select>
                        <span asp-validation-for="Frequency" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NumberOfVisits" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="NumberOfVisits" class="form-control form-control-sm" type="number" />
                        <span asp-validation-for="NumberOfVisits" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Contact Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-telephone me-1"></i>Contact Information</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="ContactPerson" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="ContactPerson" class="form-control form-control-sm" />
                        <span asp-validation-for="ContactPerson" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ContactPhone" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="ContactPhone" class="form-control form-control-sm" />
                        <span asp-validation-for="ContactPhone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ContactEmail" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="ContactEmail" class="form-control form-control-sm" type="email" />
                        <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Service Address Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-geo-alt me-1"></i>Service Address</h6>
                <div class="row g-2">
                    <div class="col-md-12">
                        <label asp-for="ServiceAddress" class="form-label small fw-semibold mb-1"></label>
                        <textarea asp-for="ServiceAddress" class="form-control form-control-sm" rows="2"></textarea>
                        <span asp-validation-for="ServiceAddress" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Description Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-file-text me-1"></i>Description</h6>
                <div class="row g-2">
                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label small fw-semibold mb-1"></label>
                        <textarea asp-for="Description" class="form-control form-control-sm" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Terms & Conditions Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-file-earmark-text me-1"></i>Terms & Conditions</h6>
                <div class="row g-2">
                    <div class="col-md-12">
                        <label asp-for="TermsConditions" class="form-label small fw-semibold mb-1"></label>
                        <textarea asp-for="TermsConditions" class="form-control form-control-sm" rows="3"></textarea>
                        <span asp-validation-for="TermsConditions" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-end gap-2 mt-2 pt-2 border-top">
                <a asp-action="Index" class="btn btn-secondary btn-sm">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </a>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-check-circle me-1"></i>Create AMC
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var customerSelect = document.getElementById('CustomerId');
            var contactPersonInput = document.getElementById('ContactPerson');
            var contactPhoneInput = document.getElementById('ContactPhone');
            var contactEmailInput = document.getElementById('ContactEmail');
            var serviceAddressInput = document.getElementById('ServiceAddress');
            
            if (customerSelect) {
                customerSelect.addEventListener('change', function() {
                    var selectedOption = this.options[this.selectedIndex];
                    
                    if (selectedOption.value && contactPersonInput && contactPhoneInput && contactEmailInput && serviceAddressInput) {
                        // Copy Contact Person
                        var contactPerson = selectedOption.getAttribute('data-contact-person');
                        if (contactPerson) {
                            contactPersonInput.value = contactPerson;
                        }
                        
                        // Copy Contact Phone
                        var contactPhone = selectedOption.getAttribute('data-contact-phone');
                        if (contactPhone) {
                            contactPhoneInput.value = contactPhone;
                        }
                        
                        // Copy Contact Email
                        var contactEmail = selectedOption.getAttribute('data-contact-email');
                        if (contactEmail) {
                            contactEmailInput.value = contactEmail;
                        }
                        
                        // Build Shipping Address from components
                        var addressLine1 = selectedOption.getAttribute('data-shipping-address-line1') || '';
                        var addressLine2 = selectedOption.getAttribute('data-shipping-address-line2') || '';
                        var city = selectedOption.getAttribute('data-shipping-city') || '';
                        var state = selectedOption.getAttribute('data-shipping-state') || '';
                        var pincode = selectedOption.getAttribute('data-shipping-pincode') || '';
                        
                        var shippingAddress = [];
                        if (addressLine1) shippingAddress.push(addressLine1);
                        if (addressLine2) shippingAddress.push(addressLine2);
                        if (city) shippingAddress.push(city);
                        if (state) shippingAddress.push(state);
                        if (pincode) shippingAddress.push(pincode);
                        
                        serviceAddressInput.value = shippingAddress.join(', ');
                    }
                });
            }
        });
    </script>
}

