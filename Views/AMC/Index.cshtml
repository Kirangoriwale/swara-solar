@model IEnumerable<SolarBilling.Models.AMC>

@{
    ViewData["Title"] = "AMC Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">
        <i class="bi bi-shield-check text-primary me-2"></i>AMC Management
    </h2>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Create New AMC
    </a>
</div>

<!-- Results Table -->
<div class="card shadow-sm rounded-lg">
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th class="text-white fw-bold">AMC Number</th>
                            <th class="text-white fw-bold">Customer</th>
                            <th class="text-white fw-bold">Start Date</th>
                            <th class="text-white fw-bold">End Date</th>
                            <th class="text-end text-white fw-bold">Amount</th>
                            <th class="text-white fw-bold">Frequency</th>
                            <th class="text-white fw-bold">Status</th>
                            <th class="text-center text-white fw-bold">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@Html.DisplayFor(modelItem => item.AMCNumber)</strong></td>
                                <td>@Html.DisplayFor(modelItem => item.Customer.Name)</td>
                                <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                                <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                                <td class="text-end">₹ @Html.DisplayFor(modelItem => item.AMCAmount)</td>
                                <td>@Html.DisplayFor(modelItem => item.Frequency)</td>
                                <td>
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success">@item.Status</span>
                                    }
                                    else if (item.Status == "Expired")
                                    {
                                        <span class="badge bg-danger">@item.Status</span>
                                    }
                                    else if (item.Status == "Cancelled")
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">@item.Status</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox display-4 text-muted"></i>
                <p class="text-muted mt-3">
                    No AMCs found. <a asp-action="Create">Create a new AMC</a> to get started.
                </p>
            </div>
        }
    </div>
</div>

