@model SolarBilling.Models.Company

@{
    ViewData["Title"] = "Create Company";
}

<div class="page-header d-flex justify-content-between align-items-center mb-2">
    <h2 class="text-primary mb-0"><i class="bi bi-building me-2"></i>Create Company</h2>
</div>

<div class="card shadow-sm rounded-lg">
    <div class="card-body p-3">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-2" role="alert"></div>
            
            <!-- Company Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-info-circle me-1"></i>Company Information</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Name" class="form-control form-control-sm" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TradeName" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="TradeName" class="form-control form-control-sm" />
                        <span asp-validation-for="TradeName" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Address Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-geo-alt me-1"></i>Address</h6>
                <div class="row g-2">
                    <div class="col-md-12">
                        <label asp-for="AddressLine1" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="AddressLine1" class="form-control form-control-sm" />
                        <span asp-validation-for="AddressLine1" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="AddressLine2" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="AddressLine2" class="form-control form-control-sm" />
                        <span asp-validation-for="AddressLine2" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="City" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="City" class="form-control form-control-sm" />
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="State" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="State" class="form-control form-control-sm" />
                        <span asp-validation-for="State" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="PinCode" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="PinCode" class="form-control form-control-sm" />
                        <span asp-validation-for="PinCode" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Contact Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-telephone me-1"></i>Contact Information</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="Phone" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Phone" class="form-control form-control-sm" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Mobile" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Mobile" class="form-control form-control-sm" />
                        <span asp-validation-for="Mobile" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Email" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Email" class="form-control form-control-sm" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="Website" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Website" class="form-control form-control-sm" />
                        <span asp-validation-for="Website" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Tax & Legal Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-file-earmark-text me-1"></i>Tax & Legal Information</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="GSTIN" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="GSTIN" class="form-control form-control-sm" />
                        <span asp-validation-for="GSTIN" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="PAN" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="PAN" class="form-control form-control-sm" />
                        <span asp-validation-for="PAN" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CIN" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="CIN" class="form-control form-control-sm" />
                        <span asp-validation-for="CIN" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Bank Details Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-bank me-1"></i>Bank Details</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="BankName" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="BankName" class="form-control form-control-sm" />
                        <span asp-validation-for="BankName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="AccountNumber" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="AccountNumber" class="form-control form-control-sm" />
                        <span asp-validation-for="AccountNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="IFSCCode" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="IFSCCode" class="form-control form-control-sm" />
                        <span asp-validation-for="IFSCCode" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BankBranch" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="BankBranch" class="form-control form-control-sm" />
                        <span asp-validation-for="BankBranch" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="UPIId" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="UPIId" class="form-control form-control-sm" />
                        <span asp-validation-for="UPIId" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Status Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-toggle-on me-1"></i>Status</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label small fw-semibold"></label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input asp-for="IsDefault" class="form-check-input" type="checkbox" />
                            <label asp-for="IsDefault" class="form-check-label small fw-semibold"></label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-end gap-2 mt-2 pt-2 border-top">
                <a asp-action="Index" class="btn btn-secondary btn-sm">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </a>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-check-circle me-1"></i>Create Company
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
