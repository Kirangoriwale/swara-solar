@model SolarBilling.Models.Company

@{
    ViewData["Title"] = "Delete Company";
}

<h2>Delete Company</h2>
<h3>Are you sure you want to delete this company?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Name)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Name)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.GSTIN)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.GSTIN)</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

