@model SolarBilling.Models.Company

@{
    ViewData["Title"] = "Edit Company";
}

<h2>Edit Company</h2>
<hr />
<div class="row">
    <div class="col-md-10">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="TradeName" class="form-label"></label>
                    <input asp-for="TradeName" class="form-control" />
                    <span asp-validation-for="TradeName" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="AddressLine1" class="form-label"></label>
                <input asp-for="AddressLine1" class="form-control" />
                <span asp-validation-for="AddressLine1" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="AddressLine2" class="form-label"></label>
                <input asp-for="AddressLine2" class="form-control" />
                <span asp-validation-for="AddressLine2" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="State" class="form-label"></label>
                    <input asp-for="State" class="form-control" />
                    <span asp-validation-for="State" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="PinCode" class="form-label"></label>
                    <input asp-for="PinCode" class="form-control" />
                    <span asp-validation-for="PinCode" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Mobile" class="form-label"></label>
                    <input asp-for="Mobile" class="form-control" />
                    <span asp-validation-for="Mobile" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Website" class="form-label"></label>
                <input asp-for="Website" class="form-control" />
                <span asp-validation-for="Website" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="GSTIN" class="form-label"></label>
                    <input asp-for="GSTIN" class="form-control" />
                    <span asp-validation-for="GSTIN" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="PAN" class="form-label"></label>
                    <input asp-for="PAN" class="form-control" />
                    <span asp-validation-for="PAN" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="CIN" class="form-label"></label>
                    <input asp-for="CIN" class="form-control" />
                    <span asp-validation-for="CIN" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="BankName" class="form-label"></label>
                    <input asp-for="BankName" class="form-control" />
                    <span asp-validation-for="BankName" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="AccountNumber" class="form-label"></label>
                    <input asp-for="AccountNumber" class="form-control" />
                    <span asp-validation-for="AccountNumber" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="IFSCCode" class="form-label"></label>
                    <input asp-for="IFSCCode" class="form-control" />
                    <span asp-validation-for="IFSCCode" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="BankBranch" class="form-label"></label>
                    <input asp-for="BankBranch" class="form-control" />
                    <span asp-validation-for="BankBranch" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="UPIId" class="form-label"></label>
                    <input asp-for="UPIId" class="form-control" />
                    <span asp-validation-for="UPIId" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check">
                        <input asp-for="IsDefault" class="form-check-input" type="checkbox" />
                        <label asp-for="IsDefault" class="form-check-label"></label>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

