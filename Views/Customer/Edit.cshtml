@model SolarBilling.Models.Customer

@{
    ViewData["Title"] = "Edit Customer";
}

<div class="page-header d-flex justify-content-between align-items-center mb-2">
    <h2 class="text-primary mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Customer</h2>
</div>

<div class="card shadow-sm rounded-lg">
    <div class="card-body p-3">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-2" role="alert"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />
            
            <!-- Customer Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-info-circle me-1"></i>Customer Information</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Name" class="form-control form-control-sm" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ContactPerson" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="ContactPerson" class="form-control form-control-sm" />
                        <span asp-validation-for="ContactPerson" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Contact Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-telephone me-1"></i>Contact Information</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="Email" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Email" class="form-control form-control-sm" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Phone" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Phone" class="form-control form-control-sm" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Mobile" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="Mobile" class="form-control form-control-sm" />
                        <span asp-validation-for="Mobile" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Billing Address Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-geo-alt me-1"></i>Billing Address</h6>
                <div class="row g-2">
                    <div class="col-md-12">
                        <label asp-for="BillingAddressLine1" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="BillingAddressLine1" class="form-control form-control-sm" />
                        <span asp-validation-for="BillingAddressLine1" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="BillingAddressLine2" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="BillingAddressLine2" class="form-control form-control-sm" />
                        <span asp-validation-for="BillingAddressLine2" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="BillingCity" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="BillingCity" class="form-control form-control-sm" />
                        <span asp-validation-for="BillingCity" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="BillingState" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="BillingState" class="form-control form-control-sm" />
                        <span asp-validation-for="BillingState" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="BillingPinCode" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="BillingPinCode" class="form-control form-control-sm" />
                        <span asp-validation-for="BillingPinCode" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Shipping Address Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-truck me-1"></i>Shipping Address</h6>
                <div class="form-check form-switch mb-2">
                    <input type="checkbox" class="form-check-input" id="sameAsBilling" />
                    <label class="form-check-label small fw-semibold" for="sameAsBilling">Same as Billing Address</label>
                </div>
                <div class="row g-2" id="shippingAddressFields">
                    <div class="col-md-12">
                        <label asp-for="ShippingAddressLine1" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="ShippingAddressLine1" class="form-control form-control-sm" />
                        <span asp-validation-for="ShippingAddressLine1" class="text-danger small"></span>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="ShippingAddressLine2" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="ShippingAddressLine2" class="form-control form-control-sm" />
                        <span asp-validation-for="ShippingAddressLine2" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ShippingCity" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="ShippingCity" class="form-control form-control-sm" />
                        <span asp-validation-for="ShippingCity" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ShippingState" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="ShippingState" class="form-control form-control-sm" />
                        <span asp-validation-for="ShippingState" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ShippingPinCode" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="ShippingPinCode" class="form-control form-control-sm" />
                        <span asp-validation-for="ShippingPinCode" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Tax Information Section -->
            <div class="mb-2">
                <h6 class="text-primary border-bottom pb-1 mb-2 small fw-semibold"><i class="bi bi-file-earmark-text me-1"></i>Tax Information</h6>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label asp-for="GSTIN" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="GSTIN" class="form-control form-control-sm" />
                        <span asp-validation-for="GSTIN" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PAN" class="form-label small fw-semibold mb-1"></label>
                        <input asp-for="PAN" class="form-control form-control-sm" />
                        <span asp-validation-for="PAN" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-end gap-2 mt-2 pt-2 border-top">
                <a asp-action="Index" class="btn btn-secondary btn-sm">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </a>
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-check-circle me-1"></i>Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var sameAsBilling = document.getElementById('sameAsBilling');
            var shippingFields = document.getElementById('shippingAddressFields');
            
            // Check if shipping address is same as billing address
            function checkSameAddress() {
                var isSame = 
                    document.getElementById('BillingAddressLine1').value === document.getElementById('ShippingAddressLine1').value &&
                    document.getElementById('BillingAddressLine2').value === document.getElementById('ShippingAddressLine2').value &&
                    document.getElementById('BillingCity').value === document.getElementById('ShippingCity').value &&
                    document.getElementById('BillingState').value === document.getElementById('ShippingState').value &&
                    document.getElementById('BillingPinCode').value === document.getElementById('ShippingPinCode').value;
                
                sameAsBilling.checked = isSame;
                if (isSame) {
                    var inputs = shippingFields.querySelectorAll('input');
                    inputs.forEach(function(input) {
                        input.readOnly = true;
                        input.style.backgroundColor = '#e9ecef';
                    });
                }
            }
            
            function toggleShippingAddress() {
                if (sameAsBilling.checked) {
                    // Copy billing address to shipping address
                    document.getElementById('ShippingAddressLine1').value = document.getElementById('BillingAddressLine1').value;
                    document.getElementById('ShippingAddressLine2').value = document.getElementById('BillingAddressLine2').value;
                    document.getElementById('ShippingCity').value = document.getElementById('BillingCity').value;
                    document.getElementById('ShippingState').value = document.getElementById('BillingState').value;
                    document.getElementById('ShippingPinCode').value = document.getElementById('BillingPinCode').value;
                    
                    // Make shipping address fields readonly (so they're still submitted)
                    var inputs = shippingFields.querySelectorAll('input');
                    inputs.forEach(function(input) {
                        input.readOnly = true;
                        input.style.backgroundColor = '#e9ecef';
                    });
                } else {
                    // Enable shipping address fields
                    var inputs = shippingFields.querySelectorAll('input');
                    inputs.forEach(function(input) {
                        input.readOnly = false;
                        input.style.backgroundColor = '';
                    });
                }
            }
            
            // Ensure fields are enabled before form submission
            var form = document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function() {
                    var inputs = shippingFields.querySelectorAll('input');
                    inputs.forEach(function(input) {
                        input.readOnly = false;
                        input.disabled = false;
                    });
                });
            }
            
            // Check on page load
            checkSameAddress();
            
            // Handle checkbox change
            sameAsBilling.addEventListener('change', toggleShippingAddress);
            sameAsBilling.addEventListener('click', toggleShippingAddress);
            
            // Update shipping address when billing address changes (if checkbox is checked)
            var billingFields = ['BillingAddressLine1', 'BillingAddressLine2', 'BillingCity', 'BillingState', 'BillingPinCode'];
            billingFields.forEach(function(fieldId) {
                var field = document.getElementById(fieldId);
                if (field) {
                    field.addEventListener('input', function() {
                        if (sameAsBilling.checked) {
                            var shippingFieldId = fieldId.replace('Billing', 'Shipping');
                            var shippingField = document.getElementById(shippingFieldId);
                            if (shippingField) {
                                shippingField.value = field.value;
                            }
                        }
                    });
                }
            });
        });
    </script>
}
