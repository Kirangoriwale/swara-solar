@model SolarBilling.Models.Customer

@{
    ViewData["Title"] = "Customer Details";
}

<div class="page-header d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-primary mb-0"><i class="bi bi-person me-2"></i>Customer Details</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>
</div>

<div class="card shadow-sm rounded-lg">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3"><i class="bi bi-person me-1"></i>@Html.DisplayNameFor(model => model.Name)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

            <dt class="col-sm-3"><i class="bi bi-person-badge me-1"></i>@Html.DisplayNameFor(model => model.ContactPerson)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ContactPerson)</dd>

            <dt class="col-sm-3"><i class="bi bi-envelope me-1"></i>@Html.DisplayNameFor(model => model.Email)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>

            <dt class="col-sm-3"><i class="bi bi-telephone me-1"></i>@Html.DisplayNameFor(model => model.Phone)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Phone)</dd>

            <dt class="col-sm-3"><i class="bi bi-phone me-1"></i>@Html.DisplayNameFor(model => model.Mobile)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Mobile)</dd>

            <dt class="col-sm-3"><i class="bi bi-file-earmark-text me-1"></i>@Html.DisplayNameFor(model => model.GSTIN)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.GSTIN)</dd>

            <dt class="col-sm-3"><i class="bi bi-file-earmark-text me-1"></i>@Html.DisplayNameFor(model => model.PAN)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.PAN)</dd>
        </dl>

        <hr class="my-3" />

        <h6 class="text-primary mb-2"><i class="bi bi-geo-alt me-1"></i>Billing Address</h6>
        <dl class="row mb-0">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.BillingAddressLine1)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.BillingAddressLine1)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.BillingAddressLine2)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.BillingAddressLine2)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.BillingCity)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.BillingCity)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.BillingState)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.BillingState)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.BillingPinCode)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.BillingPinCode)</dd>
        </dl>

        <hr class="my-3" />

        <h6 class="text-primary mb-2"><i class="bi bi-truck me-1"></i>Shipping Address</h6>
        <dl class="row mb-0">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ShippingAddressLine1)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ShippingAddressLine1)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ShippingAddressLine2)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ShippingAddressLine2)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ShippingCity)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ShippingCity)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ShippingState)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ShippingState)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ShippingPinCode)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ShippingPinCode)</dd>
        </dl>
    </div>
</div>
