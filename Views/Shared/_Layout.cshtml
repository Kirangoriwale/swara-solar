<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SolarBilling</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/css/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SolarBilling.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar-nav">
            <div class="sidebar-brand">
                <a asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-lightning-charge-fill me-2"></i>SolarBilling
                </a>
            </div>
            <nav class="sidebar-menu">
                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-2"></i>Home</a>
                <a class="nav-link" asp-area="" asp-controller="Company" asp-action="Index"><i class="bi bi-building me-2"></i>Company</a>
                <a class="nav-link" asp-area="" asp-controller="Customer" asp-action="Index"><i class="bi bi-people me-2"></i>Customers</a>
                <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index"><i class="bi bi-box-seam me-2"></i>Products</a>
                <a class="nav-link" asp-area="" asp-controller="Quotation" asp-action="Index"><i class="bi bi-file-earmark-text me-2"></i>Quotations</a>
                <a class="nav-link" asp-area="" asp-controller="Invoice" asp-action="Index"><i class="bi bi-receipt me-2"></i>Invoices</a>
                <a class="nav-link" asp-area="" asp-controller="AMC" asp-action="Index"><i class="bi bi-shield-check me-2"></i>AMC Management</a>
                <a class="nav-link" asp-area="" asp-controller="ServiceVisit" asp-action="Index"><i class="bi bi-tools me-2"></i>Service Visits</a>
                <a class="nav-link" asp-area="" asp-controller="ServiceVisit" asp-action="Upcoming"><i class="bi bi-calendar-check me-2"></i>Upcoming Visits</a>
            </nav>
        </aside>
        <div class="content-shell">
            <header class="topbar-mobile d-lg-none">
                <div class="container-fluid d-flex justify-content-between align-items-center py-2">
                    <a class="navbar-brand m-0" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-lightning-charge-fill me-2"></i>SolarBilling
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileNav" aria-controls="mobileNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
            </header>

            <div class="offcanvas offcanvas-start d-lg-none" tabindex="-1" id="mobileNav" aria-labelledby="mobileNavLabel">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title" id="mobileNavLabel">Menu</h5>
                    <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body">
                    <nav class="sidebar-menu">
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-2"></i>Home</a>
                        <a class="nav-link" asp-area="" asp-controller="Company" asp-action="Index"><i class="bi bi-building me-2"></i>Company</a>
                        <a class="nav-link" asp-area="" asp-controller="Customer" asp-action="Index"><i class="bi bi-people me-2"></i>Customers</a>
                        <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index"><i class="bi bi-box-seam me-2"></i>Products</a>
                        <a class="nav-link" asp-area="" asp-controller="Quotation" asp-action="Index"><i class="bi bi-file-earmark-text me-2"></i>Quotations</a>
                        <a class="nav-link" asp-area="" asp-controller="Invoice" asp-action="Index"><i class="bi bi-receipt me-2"></i>Invoices</a>
                        <a class="nav-link" asp-area="" asp-controller="AMC" asp-action="Index"><i class="bi bi-shield-check me-2"></i>AMC Management</a>
                        <a class="nav-link" asp-area="" asp-controller="ServiceVisit" asp-action="Index"><i class="bi bi-tools me-2"></i>Service Visits</a>
                        <a class="nav-link" asp-area="" asp-controller="ServiceVisit" asp-action="Upcoming"><i class="bi bi-calendar-check me-2"></i>Upcoming Visits</a>
                    </nav>
                </div>
            </div>
            <div class="main-content-wrapper">
                <div class="container">
                    <main role="main" class="pb-3">
                        @RenderBody()
                    </main>
                </div>
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    &copy; 2026 - SolarBilling - All Rights Reserved | Developed by <a href="https://www.linkedin.com/in/kiran-goriwale-9a6a19193/" target="_blank" class="text-decoration-none">Kiran Goriwale - 9892140241</a>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy Policy</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
